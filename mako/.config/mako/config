# Catppuccin Mocha theme for Mako

font=Monospace 10
background-color=#1e1e2e
text-color=#cdd6f4
border-color=#cba6f7
progress-color=#a6e3a1

width=350
height=150
margin=15
padding=15
border-radius=8
border-size=2
default-timeout=5000
max-visible=5

[urgency=low]
border-color=#6c7086
default-timeout=3000

[urgency=normal]
border-color=#cba6f7
default-timeout=5000

[urgency=high]
border-color=#f38ba8
default-timeout=8000
